<!-- Шапка сайта (белая) -->
<header class="header" id="header">
    <div class="logo-area">
        <i class="fas fa-cubes" style="margin-right: 8px;"></i> WebDesktop
    </div>
    <div class="nav-panel">
        <!-- Кнопка переключения темы (полумесяц / солнце) -->
        <button class="nav-btn theme-toggle" id="themeToggle">
            <i id="themeIcon" class="fas fa-moon"></i>
            <span id="themeText">Тёмная</span>
        </button>
        <button class="nav-btn" id="orders_button" title="Заказы"><i class="fas fa-id-card"></i> Заказы</button>
        <button class="nav-btn" id="material_button" title="Сырьё"><i class="fas fa-basket-shopping"></i> Сырьё</button>
        <button class="nav-btn" id="items_button" title="Товары"><i class="fas fa-blender"></i> Товары</button>
        <button class="nav-btn" id="auth_button" title="Вход"><i class="fas fa-sign-in-alt"></i> Вход</button>
        <!-- Кнопка Рабочий стол -->
        <button class="nav-btn" id="desktop_button" title="Рабочий стол"><i class="fas fa-desktop"></i> Рабочий стол</button>
        <!-- Кнопка Файловая система -->
        <button class="nav-btn" id="file_button" title="Файловая система"><i class="fas fa-folder-tree"></i> Файловая система</button>
    </div>
</header>